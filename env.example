# Ollama configuration
OLLAMA_HOST=http://localhost:11434

# OpenAI configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# LLM provider selection (options: "ollama" or "openai")
LLM_PROVIDER=ollama

# Incident IQ API configuration
INCIDENT_IQ_API_KEY=your_api_key_here
INCIDENT_IQ_BASE_URL=https://your_instance.incidentiq.com/api/v1

# Application settings
LOG_LEVEL=INFO
PORT=8000 